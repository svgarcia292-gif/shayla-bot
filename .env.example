# Shayla Bot Configuration

# REQUIRED: Telegram Bot Token (get it from @BotFather on Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Optional: Bot username (for reference)
BOT_USERNAME=ShaylaBot

# Optional: Your Telegram user ID (for owner-only commands)
OWNER_ID=0

# Whisper configuration
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large
# Larger models are more accurate but require more RAM/CPU

# Audio configuration
AUDIO_MAX_DURATION=120

# Database
DATABASE_PATH=data/shayla.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/shayla.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Access control (optional: comma-separated user IDs)
# Leave empty for public access
ALLOWED_USERS=

# Web search
WEB_SEARCH_ENABLED=true
MAX_SEARCH_RESULTS=5
